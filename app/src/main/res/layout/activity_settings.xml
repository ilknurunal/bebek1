<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="24dp"
    android:background="@drawable/baby_arkaplan"
    tools:context=".SettingsActivity">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="10dp"
            app:cardBackgroundColor="#FFFFFF"
            android:layout_marginVertical="32dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="👶 Bebeğinizi Tanıyalım"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="24dp"
                    android:textColor="#333333"/>

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">
                    <EditText
                        android:id="@+id/editText_bebekAdi"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Bebeğin Adı (Örn: Ela)"
                        android:inputType="textCapWords" />
                </com.google.android.material.textfield.TextInputLayout>

                <Button
                    android:id="@+id/button_dogumTarihiSec"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="📅 Doğum Tarihini Seç: --/--/----"
                    android:backgroundTint="#FFCCBC"
                    android:textColor="@color/black" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Fiziksel Veriler"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginTop="24dp"
                    android:textColor="#333333"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="8dp">

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">
                        <EditText
                            android:id="@+id/editText_bebekBoy"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Boy (cm)"
                            android:inputType="numberDecimal" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="8dp"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">
                        <EditText
                            android:id="@+id/editText_bebekKilo"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Kilo (kg)"
                            android:inputType="numberDecimal" />
                    </com.google.android.material.textfield.TextInputLayout>
                </LinearLayout>

                <TextView
                    android:id="@+id/textView_saglikBaslik"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="▼ Sağlık Bilgileri (Opsiyonel)"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginTop="24dp"
                    android:paddingVertical="8dp"
                    android:background="#F0F0F0"
                    android:gravity="center"
                    android:clickable="true"
                    android:focusable="true"
                    android:textColor="#333333"/>

                <LinearLayout
                    android:id="@+id/layout_saglikDetaylari"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="Kan Grubu Seçimi:"
                        android:textColor="#333333"/>

                    <Spinner
                        android:id="@+id/spinner_kanGrubu"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:padding="12dp"
                        style="@android:style/Widget.Holo.Light.Spinner" />

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">
                        <EditText
                            android:id="@+id/editText_hastalik"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Hastalıklar (Virgülle Ayırın)"
                            android:inputType="textMultiLine"
                            android:minLines="3" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:layout_marginBottom="8dp"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">
                        <EditText
                            android:id="@+id/editText_alerji"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Alerjiler (Virgülle Ayırın)"
                            android:inputType="textMultiLine"
                            android:minLines="3" />
                    </com.google.android.material.textfield.TextInputLayout>
                </LinearLayout>
                <TextView
                    android:id="@+id/textView_asiIacBaslik"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="▼ Aşı ve İlaç Geçmişi (Son Kayıt)"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginTop="24dp"
                    android:paddingVertical="8dp"
                    android:background="#F0F0F0"
                    android:gravity="center"
                    android:clickable="true"
                    android:focusable="true"
                    android:textColor="#333333"/>

                <LinearLayout
                    android:id="@+id/layout_asiIacDetaylari"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="AŞI BİLGİSİ"
                        android:textSize="16sp"
                        android:textStyle="bold"/>

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">
                        <EditText
                            android:id="@+id/editText_asiAdi"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Aşı Adı (Örn: Rotavirüs)"
                            android:inputType="textCapWords" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <Button
                        android:id="@+id/button_asiTarihiSec"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="📅 Aşı Tarihini Seç: --/--/----"
                        android:backgroundTint="#B2EBF2"
                        android:textColor="@color/black" />

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">
                        <EditText
                            android:id="@+id/editText_asiDozu"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Doz/Ek Not (Örn: 1. Doz)"
                            android:inputType="textCapSentences" />
                    </com.google.android.material.textfield.TextInputLayout>


                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="24dp"
                        android:text="İLAÇ BİLGİSİ"
                        android:textSize="16sp"
                        android:textStyle="bold"/>

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">
                        <EditText
                            android:id="@+id/editText_ilacAdi"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="İlaç Adı"
                            android:inputType="textCapWords" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <Button
                        android:id="@+id/button_ilacTarihiSec"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="📅 İlaç Tarihini Seç: --/--/----"
                        android:backgroundTint="#B2EBF2"
                        android:textColor="@color/black" />

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:layout_marginBottom="8dp"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">
                        <EditText
                            android:id="@+id/editText_ilacDozu"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Doz/Süre (Örn: 5 ml)"
                            android:inputType="textCapSentences" />
                    </com.google.android.material.textfield.TextInputLayout>
                </LinearLayout>
                <Button
                    android:id="@+id/button_ayarlariKaydet"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="32dp"
                    android:text="Ayarları Kaydet ve Başla"
                    android:backgroundTint="#90CAF9" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>