<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="@drawable/baby_arkaplan"
    android:gravity="center_horizontal"
    tools:context=".MainActivity">

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="8dp"
        app:cardBackgroundColor="#FFFDE7"
        android:layout_marginBottom="32dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:gravity="center">

            <TextView
                android:id="@+id/textView_bebekAdi"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="👶 Minik Bebek"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="#FFC107" />

            <TextView
                android:id="@+id/textView_bebekYasi"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Yaş Verisi Yok (Ayarlayın)"
                android:textSize="16sp"
                android:textColor="#404040"
                android:layout_marginTop="4dp" />

            <TextView
                android:id="@+id/textView_bebekBoyKilo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Boy: -- cm | Kilo: -- kg"
                android:textSize="14sp"
                android:textColor="#808080"
                android:layout_marginTop="4dp" />

        </LinearLayout>
    </androidx.cardview.widget.CardView>
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="0dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="8dp"
        app:cardBackgroundColor="#E0F7FA"
        android:layout_marginBottom="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🤱 SON BESLENME"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#0097A7" />

            <TextView
                android:id="@+id/textView_beslenmeGecenSure"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginVertical="12dp"
                android:text="..."
                android:textSize="32sp"
                android:textStyle="bold"
                android:textColor="#00BCD4" />

            <TextView
                android:id="@+id/textView_sonBeslenmeZamani"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Kaydedilen Zaman: Veri Yok"
                android:textSize="14sp"
                android:textColor="#404040" />

            <Button
                android:id="@+id/button_beslenmeyiKaydet"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="BESLEMEYİ KAYDET"
                app:cornerRadius="12dp"
                android:backgroundTint="#FFCCBC"
                android:textColor="@color/black" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="16dp"
        app:cardElevation="8dp"
        app:cardBackgroundColor="#FFF3E0"
        android:layout_marginTop="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="😴 SON UYKU"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#FF9800" />

            <TextView
                android:id="@+id/textView_uykuGecenSure"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginVertical="12dp"
                android:text="..."
                android:textSize="32sp"
                android:textStyle="bold"
                android:textColor="#FFB74D" />

            <TextView
                android:id="@+id/textView_sonUykuZamani"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Kaydedilen Zaman: Veri Yok"
                android:textSize="14sp"
                android:textColor="#404040" />

            <Button
                android:id="@+id/button_uykuyuKaydet"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="UYKUYU KAYDET"
                app:cornerRadius="12dp"
                android:backgroundTint="#90CAF9"
                android:textColor="@color/black" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

</LinearLayout>